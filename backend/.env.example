# ============================================================
# IELTS Scholar Platform — Environment Variables
# Copy to .env and fill in values before running
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development                     # development | production
FRONTEND_URL=http://localhost:3000

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/ielts_platform

# --- Redis (BullMQ queue) ---
REDIS_URL=redis://localhost:6379        # or Redis Cloud URL

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-64-chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# --- AI: Anthropic (primary — Claude Sonnet) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- AI: OpenAI (Whisper for audio transcription) ---
OPENAI_API_KEY=sk-...

# --- AWS S3 / Cloudflare R2 (audio file storage) ---
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=ielts-audio-files
# Leave blank to use AWS S3; set to R2 endpoint for Cloudflare
AWS_ENDPOINT=

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_signing_secret
RAZORPAY_MONTHLY_PLAN_ID=plan_monthly_id
RAZORPAY_ANNUAL_PLAN_ID=plan_annual_id

# --- Email (Resend recommended; SMTP also works) ---
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_...
FROM_EMAIL=noreply@ieltsscholar.com
FROM_NAME=IELTS Scholar

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000             # 15 minutes
RATE_LIMIT_MAX=100                      # requests per window per IP
AUTH_RATE_LIMIT_MAX=10                  # stricter limit for auth routes

# --- Feature Flags ---
ENABLE_MOCK_AI=false                    # true = use mock AI responses (dev only)

# ─── Storage: Cloudflare R2 (S3-compatible, zero egress fees) ─────────────────
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
AWS_REGION=auto
AWS_ENDPOINT=https://<YOUR_ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET_NAME=ielts-platform

# Public bucket URL (R2 custom domain or r2.dev subdomain)
# Set this in Cloudflare → R2 → your bucket → Settings → Public Access
STORAGE_PUBLIC_URL=https://your-bucket.your-domain.com
